# ══════════════════════════════════════════════════════════════
# Auth Database
# ══════════════════════════════════════════════════════════════
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=change_me_auth
AUTH_DB_NAME=auth_db
AUTH_DB_PORT=5433

# ══════════════════════════════════════════════════════════════
# Orders Database
# ══════════════════════════════════════════════════════════════
ORDERS_DB_USER=orders_user
ORDERS_DB_PASSWORD=change_me_orders
ORDERS_DB_NAME=orders_db
ORDERS_DB_PORT=5434

# ══════════════════════════════════════════════════════════════
# JWT (RS256 — asymmetric)
# Generate keys with:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in private.pem -pubout -out public.pem
#
# Then encode newlines: awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem
# Paste the result as the value below (wrapped in quotes).
# ══════════════════════════════════════════════════════════════
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ══════════════════════════════════════════════════════════════
# Gateway
# ══════════════════════════════════════════════════════════════
GATEWAY_PORT=8080
