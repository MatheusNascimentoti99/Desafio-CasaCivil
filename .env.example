# ══════════════════════════════════════════════════════════════
# Auth Database
# ══════════════════════════════════════════════════════════════
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=change_me_auth
AUTH_DB_NAME=auth_db
AUTH_DB_PORT=5433

# ══════════════════════════════════════════════════════════════
# Orders Database
# ══════════════════════════════════════════════════════════════
ORDERS_DB_USER=orders_user
ORDERS_DB_PASSWORD=change_me_orders
ORDERS_DB_NAME=orders_db
ORDERS_DB_PORT=5434

# ══════════════════════════════════════════════════════════════
# JWT (shared between auth and orders services)
# ══════════════════════════════════════════════════════════════
SECRET_KEY=change-me-use-a-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ══════════════════════════════════════════════════════════════
# Gateway
# ══════════════════════════════════════════════════════════════
GATEWAY_PORT=8080
