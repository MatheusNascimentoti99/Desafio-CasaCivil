# ══════════════════════════════════════════════════════════════
# Auth Database
# ══════════════════════════════════════════════════════════════
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=change_me_auth
AUTH_DB_NAME=auth_db
AUTH_DB_PORT=5433
AUTH_DB_HOST=auth-db

# ══════════════════════════════════════════════════════════════
# Orders Database
# ══════════════════════════════════════════════════════════════
ORDERS_DB_USER=orders_user
ORDERS_DB_PASSWORD=change_me_orders
ORDERS_DB_NAME=orders_db
ORDERS_DB_PORT=5434
ORDERS_DB_HOST=orders-db

# ══════════════════════════════════════════════════════════════
# JWT (RS256 — asymmetric)
# Generate keys with:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in private.pem -pubout -out public.pem
#
# Then encode newlines: awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem
# Paste the result as the value below (wrapped in quotes).
# ══════════════════════════════════════════════════════════════
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ══════════════════════════════════════════════════════════════
# Redis / Cache
# ══════════════════════════════════════════════════════════════
REDIS_PORT=6379
CACHE_ENABLED=true
CACHE_TTL_ORDER=600
CACHE_TTL_AUTH=600

# Opcional: ao definir REDIS_URL aqui, auth-service e orders-service
# usarão o mesmo DB de Redis. Se quiser manter isolamento por serviço,
# deixe sem definir para usar os defaults do compose (/1 para auth e /0 para orders).
# REDIS_URL=redis://redis:6379/0

# ══════════════════════════════════════════════════════════════
# BFF
# ══════════════════════════════════════════════════════════════
AUTH_SERVICE_URL=http://auth-service:8001
ORDERS_SERVICE_URL=http://orders-service:8002
BFF_COOKIE_NAME=bff_session
BFF_COOKIE_SECURE=false
BFF_COOKIE_SAMESITE=lax
BFF_COOKIE_MAX_AGE=3600
BFF_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:5174

# ══════════════════════════════════════════════════════════════
# Frontend
# ══════════════════════════════════════════════════════════════
APP_HOST_PORT=3000
MFE_ORDERS_PORT=3001
VITE_ORDERS_MFE_URL=http://localhost:3001/assets/remoteEntry.js

# ══════════════════════════════════════════════════════════════
# Gateway
# ══════════════════════════════════════════════════════════════
GATEWAY_PORT=8080
